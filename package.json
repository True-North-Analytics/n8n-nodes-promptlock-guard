{
	"name": "n8n-nodes-promptlock-guard",
	"version": "1.0.13",
	"description": "AI-powered security guardrails for n8n workflows - analyze, redact, or block content based on HIPAA, GDPR, and PCI compliance frameworks",
	"keywords": [
		"n8n",
		"n8n-community-node-package",
		"security",
		"guardrails",
		"compliance",
		"AI",
		"content-analysis",
		"HIPAA",
		"GDPR",
		"PCI",
		"data-protection",
		"privacy",
		"automation",
		"workflow-security",
		"prompt-injection",
		"content-filtering"
	],
	"license": "MIT",
	"author": {
		"name": "PromptLock Team",
		"email": "support@promptlock.io"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/True-North-Analytics/n8n-nodes-promptlock-guard.git"
	},
	"main": "index.js",
	"engines": {
		"node": ">=22.0.0",
		"npm": ">=8.0.0"
	},
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint nodes credentials package.json",
		"lintfix": "eslint nodes credentials package.json --fix",
		"release": "n8n-node release",
		"test": "jest",
		"test:watch": "jest --watch",
		"clean": "rm -rf dist",
		"prepack": "npm run clean && npm run build && npm run test",
		"prepublishOnly": "npm run prepack"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"index.js"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/PromptLockApiKey.credentials.js"
		],
		"nodes": [
			"dist/nodes/PromptLockGuard/PromptLockGuard.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.23.0",
		"@types/jest": "^29.0.0",
		"@types/node": "^20.0.0",
		"@typescript-eslint/parser": "^6.0.0",
		"eslint": "^8.0.0",
		"eslint-plugin-n8n-nodes-base": "^1.0.0",
		"gulp": "^4.0.2",
		"jest": "^29.0.0",
		"n8n-workflow": "~1.0.0",
		"prettier": "^3.0.0",
		"typescript": "^5.4.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"jest": {
		"testEnvironment": "node",
		"testMatch": [
			"**/test/**/*.test.js"
		],
		"collectCoverageFrom": [
			"dist/**/*.js",
			"!dist/**/*.d.ts"
		]
	}
}

